{
  "name": "@cinatra-ai/email-follow-up-agent",
  "version": "0.1.2",
  "license": "Apache-2.0",
  "files": [
    "cinatra",
    "skills"
  ],
  "description": "Generates follow-up email drafts and schedules their cadence for an email outreach campaign.",
  "type": "module",
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "displayName": "Email Follow-up Agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/reviewer-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "^0.1.0"
        },
        "requirement": "required",
        "kind": "agent"
      }
    ],
    "agentDependencies": {
      "@cinatra-ai/reviewer-agent": "^0.1.0"
    },
    "produces": [
      {
        "extension": "@cinatra-ai/email-body-artifact"
      }
    ],
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/email-follow-up-agent:follow-up-cadence",
        "kind": "follow-up-cadence",
        "priority": 90
      },
      {
        "id": "@cinatra-ai/email-follow-up-agent:output",
        "kind": "email-drafts-review",
        "priority": 80,
        "a2uiTranslator": "followups-output"
      }
    ],
    "consumes": [],
    "packageType": "agent",
    "manifestVersion": 1,
    "sourceTemplateId": "email-follow-up-flow",
    "sourceVersionId": "ff2305ae-0aeb-441a-bce2-813390f38eda",
    "sourceVersionNumber": 1,
    "riskLevel": "low",
    "hasApprovalGates": true,
    "toolAccess": [],
    "ownerOrgId": null
  }
}
