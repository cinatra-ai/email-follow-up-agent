{
  "name": "@cinatra-ai/email-follow-up-agent",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Generates follow-up email drafts and schedules their cadence for an email outreach campaign.",
  "type": "module",
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/reviewer-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "*"
        },
        "requirement": "required",
        "kind": "agent"
      }
    ],
    "agentDependencies": {
      "@cinatra-ai/reviewer-agent": "^0.1.0"
    }
  }
}
