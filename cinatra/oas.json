{
  "agentspec_version": "26.1.0",
  "component_type": "Flow",
  "id": "email-follow-up-flow",
  "name": "Email Follow-up Agent",
  "description": "Generates follow-up email drafts for recipients who did not respond to the initial outreach.",
  "metadata": {
    "cinatra": {
      "type": "node",
      "hitlScreens": [
        "@cinatra-ai/reviewer-agent:output"
      ],
      "packageName": "@cinatra-ai/email-follow-up-agent",
      "produces": [
        {
          "extension": "@cinatra-ai/email-artifacts",
          "objectTypeId": "@cinatra-ai/email:body"
        }
      ]
    }
  },
  "inputs": [
    {
      "title": "campaignId",
      "type": "string",
      "json_schema": {
        "format": "uuid"
      }
    },
    {
      "title": "followUpDays",
      "type": "array",
      "json_schema": {
        "items": {
          "type": "integer"
        }
      }
    },
    {
      "title": "agent_run_id",
      "type": "string",
      "default": ""
    }
  ],
  "outputs": [
    {
      "title": "followupBundle",
      "type": "object"
    },
    {
      "title": "followupDigest",
      "type": "string"
    },
    {
      "title": "summary",
      "type": "string"
    },
    {
      "title": "userResponse",
      "type": "string"
    }
  ],
  "start_node": {
    "$component_ref": "start"
  },
  "nodes": [
    {
      "$component_ref": "start"
    },
    {
      "$component_ref": "followup"
    },
    {
      "$component_ref": "approval_gate"
    },
    {
      "$component_ref": "apply"
    },
    {
      "$component_ref": "end"
    }
  ],
  "control_flow_connections": [
    {
      "component_type": "ControlFlowEdge",
      "name": "start_to_followup",
      "from_node": {
        "$component_ref": "start"
      },
      "to_node": {
        "$component_ref": "followup"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "followup_to_approval_gate",
      "from_node": {
        "$component_ref": "followup"
      },
      "to_node": {
        "$component_ref": "approval_gate"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "approval_gate_to_apply",
      "from_node": {
        "$component_ref": "approval_gate"
      },
      "to_node": {
        "$component_ref": "apply"
      }
    },
    {
      "component_type": "ControlFlowEdge",
      "name": "apply_to_end",
      "from_node": {
        "$component_ref": "apply"
      },
      "to_node": {
        "$component_ref": "end"
      }
    }
  ],
  "data_flow_connections": [
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_followup_campaignId",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "campaignId",
      "destination_node": {
        "$component_ref": "followup"
      },
      "destination_input": "campaignId"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_followup_followUpDays",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "followUpDays",
      "destination_node": {
        "$component_ref": "followup"
      },
      "destination_input": "followUpDays"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_followup_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "agent_run_id",
      "destination_node": {
        "$component_ref": "followup"
      },
      "destination_input": "agent_run_id"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "apply_to_end_followupBundle",
      "source_node": {
        "$component_ref": "apply"
      },
      "source_output": "reviewedBundle",
      "destination_node": {
        "$component_ref": "end"
      },
      "destination_input": "followupBundle"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "apply_to_end_followupDigest",
      "source_node": {
        "$component_ref": "apply"
      },
      "source_output": "reviewedDocument",
      "destination_node": {
        "$component_ref": "end"
      },
      "destination_input": "followupDigest"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "followup_to_end_summary",
      "source_node": {
        "$component_ref": "followup"
      },
      "source_output": "summary",
      "destination_node": {
        "$component_ref": "end"
      },
      "destination_input": "summary"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "approval_gate_to_end_userResponse",
      "source_node": {
        "$component_ref": "approval_gate"
      },
      "source_output": "userResponse",
      "destination_node": {
        "$component_ref": "end"
      },
      "destination_input": "userResponse"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "followup_to_approval_gate_followupBundle",
      "source_node": {
        "$component_ref": "followup"
      },
      "source_output": "followupBundle",
      "destination_node": {
        "$component_ref": "approval_gate"
      },
      "destination_input": "followupBundle"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "approval_gate_to_apply_resumePayload",
      "source_node": {
        "$component_ref": "approval_gate"
      },
      "source_output": "userResponse",
      "destination_node": {
        "$component_ref": "apply"
      },
      "destination_input": "resumePayload"
    },
    {
      "component_type": "DataFlowEdge",
      "name": "start_to_apply_agent_run_id",
      "source_node": {
        "$component_ref": "start"
      },
      "source_output": "agent_run_id",
      "destination_node": {
        "$component_ref": "apply"
      },
      "destination_input": "agent_run_id"
    }
  ],
  "$referenced_components": {
    "start": {
      "component_type": "StartNode",
      "id": "start",
      "name": "Inputs",
      "metadata": {
        "cinatra": {
          "required": [
            "campaignId"
          ],
          "hidden": [
            "campaignId",
            "agent_run_id"
          ],
          "inputRenderers": {
            "followUpDays": "@cinatra-ai/email-follow-up-agent:follow-up-cadence"
          }
        }
      },
      "inputs": [
        {
          "title": "campaignId",
          "type": "string",
          "json_schema": {
            "format": "uuid"
          }
        },
        {
          "title": "followUpDays",
          "type": "array",
          "json_schema": {
            "items": {
              "type": "integer"
            }
          }
        },
        {
          "title": "agent_run_id",
          "type": "string",
          "default": ""
        }
      ]
    },
    "followup": {
      "component_type": "ApiNode",
      "id": "followup",
      "name": "Draft follow-up emails",
      "url": "{{CINATRA_BASE_URL}}/api/llm-bridge",
      "http_method": "POST",
      "data": {
        "system": "You are an email follow-up drafting agent. Generate a follow-up email sequence for an outreach campaign and return it as JSON with exactly three top-level keys: {\"followupBundle\":{\"draftedEmails\":[{\"recipientId\":\"follow-up-<stepNumber>\",\"recipientName\":\"\",\"recipientEmail\":\"\",\"subject\":\"<subject>\",\"body\":\"<body>\",\"followUpDay\":<day offset>}],\"summary\":\"<one sentence summary>\"},\"followupDigest\":\"<markdown>\",\"summary\":\"<same one sentence summary>\"}. `followupDigest` MUST be a verbatim Markdown rendering of `followupBundle.draftedEmails` — one `## Follow-up <stepNumber> (day <followUpDay>)` section per drafted email, each followed by `**Subject:** <subject>` then the body — never independently redrafted content. PERSIST STEP — BEFORE returning the JSON, call objects_save EXACTLY ONCE to write the generated bundle as this run's pre-gate follow-up-bundle record so the re-entrant review gate can load and update it. Use exactly this structure:\n  objects_save({\"typeHint\":\"@cinatra-ai/campaigns:email-followup-bundle\",\"rawData\":{\"cinatra_agent_run_id\":\"<the agent_run_id input>\",\"campaignId\":\"<the campaignId input>\",\"draftedEmails\":[ ...the SAME draftedEmails array you return in followupBundle... ],\"summary\":\"<the same summary>\"}})\nCall objects_save once only — do not save any other object type and do not send email; this agent only drafts follow-ups.",
        "user": "Execute the follow-up drafting task now and return the result as JSON.\nInputs:\n- campaignId: {{ campaignId }}\n- followUpDays: {{ followUpDays }}\n- agent_run_id: {{ agent_run_id }}",
        "agent_id": "email-follow-up",
        "agent_run_id": "{{ agent_run_id }}",
        "cinatra_llm": {
          "preferredProvider": "openai",
          "preferredModel": "gpt-5.5"
        }
      },
      "outputs": [
        {
          "title": "followupBundle",
          "type": "object"
        },
        {
          "title": "followupDigest",
          "type": "string"
        },
        {
          "title": "summary",
          "type": "string"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "draft_create",
          "requiresApproval": false
        }
      }
    },
    "end": {
      "component_type": "EndNode",
      "id": "end",
      "name": "End",
      "outputs": [
        {
          "title": "followupBundle",
          "type": "object"
        },
        {
          "title": "followupDigest",
          "type": "string",
          "cinatra": {
            "artifact": {
              "extension": "@cinatra-ai/email-artifacts",
              "objectTypeId": "@cinatra-ai/email:body",
              "contentFrom": "followupDigest",
              "declaredMime": "text/markdown",
              "titleFrom": "summary"
            }
          }
        },
        {
          "title": "summary",
          "type": "string"
        },
        {
          "title": "userResponse",
          "type": "string"
        }
      ]
    },
    "approval_gate": {
      "component_type": "InputMessageNode",
      "id": "approval_gate",
      "name": "Review and approve",
      "metadata": {
        "cinatra": {
          "riskClass": "approval",
          "requiresApproval": true,
          "renderer": "@cinatra-ai/email-follow-up-agent:email-drafts-review",
          "a2uiSurfaceId": "reviewer:approval-gate:input",
          "surfaceGateInputs": true
        }
      },
      "inputs": [
        {
          "title": "followupBundle",
          "type": "object"
        }
      ],
      "outputs": [
        {
          "title": "userResponse",
          "type": "string"
        }
      ]
    },
    "apply": {
      "component_type": "ApiNode",
      "id": "apply",
      "name": "Persist reviewed follow-ups",
      "url": "{{CINATRA_BASE_URL}}/api/agents/passthrough",
      "http_method": "POST",
      "data": {
        "tool": "email_outreach_initial_drafts_update",
        "input": {
          "resumePayloadJson": "{{ resumePayload }}"
        },
        "agent_run_id": "{{ agent_run_id }}"
      },
      "outputs": [
        {
          "title": "ok",
          "type": "boolean"
        },
        {
          "title": "reviewedBundle",
          "type": "object"
        },
        {
          "title": "reviewedDocument",
          "type": "string"
        }
      ],
      "metadata": {
        "cinatra": {
          "riskClass": "draft_update",
          "requiresApproval": false
        }
      }
    }
  }
}
